{
  "private": true,
  "name": "versatiles-landcover",
  "version": "1.0.0",
  "description": "Generate landcover vector tiles from ESA Worldcover",
  "author": "Michael Kreil <github@michael-kreil.de>, yetzt <node@yetzt.me>",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "check": "npm run typecheck && npm run format:check",
    "download": "node bin/download.ts",
    "build": "node bin/build.ts",
    "style": "node bin/style.ts",
    "clean": "node bin/clean.ts",
    "typecheck": "tsc --noEmit",
    "upgrade": "npx npm-check-updates -u && npm install",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}