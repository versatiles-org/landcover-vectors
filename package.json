{
  "private": true,
  "name": "versatiles-landcover",
  "version": "1.0.0",
  "description": "Generate landcover vector tiles from ESA Worldcover",
  "author": "yetzt <node@yetzt.me>",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "download": "node bin/download-worldcover.js",
    "polygonize": "node bin/polygonize-worldcover.js",
    "tile": "node bin/tile-worldcover.js",
    "pack": "versatiles convert -c brotli data/landcover.mbtiles landcover-vectors.versatiles",
    "build": "npm run download && npm run polygonize && npm run tile && npm run pack",
    "upgrade": "npx npm-check-updates -u && npm install",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "potrace-wasm": "github:IguteChung/potrace-wasm",
    "sharp": "^0.34.5",
    "svg-path-to-polygons": "^0.1.0",
    "vtt": "^0.0.3"
  },
  "devDependencies": {
    "npm-check-updates": "^22.2.3",
    "prettier": "^3.8.4"
  }
}
