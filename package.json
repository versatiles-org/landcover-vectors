{
  "private": true,
  "name": "versatiles-landcover",
  "version": "1.0.0",
  "description": "Generate landcover vector tiles from ESA Worldcover",
  "author": "yetzt <node@yetzt.me>",
  "license": "Unlicense",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "import": "node bin/import-worldcover.js",
    "extract": "node bin/extract-channels.js",
    "render": "node bin/render.js",
    "simplify": "node bin/simplify.js",
    "pack": "versatiles convert -c brotli tiles/vectortiles-simplified landcover-vectors.versatiles",
    "build": "npm run import && npm run extract && npm run render && npm run simplify && npm run pack",
    "upgrade": "npx npm-check-updates -u && npm install",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "potrace-wasm": "github:IguteChung/potrace-wasm",
    "sharp": "^0.34.5",
    "svg-path-to-polygons": "^0.1.0",
    "vtt": "^0.0.3"
  },
  "devDependencies": {
    "npm-check-updates": "^22.2.3",
    "prettier": "^3.8.4"
  }
}
