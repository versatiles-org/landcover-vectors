{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["esnext"],
		"types": ["node"],

		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,

		// run via Node's native type stripping: type-check only, never emit, and require
		// import specifiers to carry the real ".ts" extension (erasable syntax only)
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"skipLibCheck": true
	},
	"include": ["config.ts", "bin/**/*.ts", "lib/**/*.ts"]
}
